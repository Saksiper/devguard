{
  "name": "devguard",
  "version": "0.3.3",
  "description": "Vibe coding guardian — cycle detection & cross-concern protection for Claude Code",
  "author": "Umut Uygun",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Saksiper/devguard.git"
  },
  "homepage": "https://github.com/Saksiper/devguard#readme",
  "bugs": {
    "url": "https://github.com/Saksiper/devguard/issues"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "ci": "npm run lint && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\""
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.8.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^1.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "vitest": "^3.1.0"
  }
}
